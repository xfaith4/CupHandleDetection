{
  "name": "cup-handle-detection",
  "private": true,
  "version": "0.1.0",
  "description": "Cup-with-handle detection pipeline and workbench UI.",
  "scripts": {
    "ui": "pwsh -NoProfile -File ./scripts/Start-CupHandleWorkbench.ps1",
    "ui:install": "npm --prefix ui/workbench install",
    "ui:build": "pwsh -NoProfile -File ./scripts/Start-CupHandleWorkbench.ps1 -Build",
    "ui:preview": "npm --prefix ui/workbench run preview",
    "detect": "pwsh -NoProfile -File ./scripts/Invoke-CupHandleDetection.ps1",
    "test:pester": "pwsh -NoProfile -Command \"Invoke-Pester -Path ./tests -Output Detailed\"",
    "check": "npm run ui:build"
  }
}
