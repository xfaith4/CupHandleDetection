      "entry": {
        "atr_add_k": 0.10,
        "max_chase_atr": 0.75,
        "min_volume_confirm_for_entry": true
      },
      "stop": {
        "type": "handle_low",
        "atr_buffer_k": 0.10,
        "max_stop_pct": 0.12
      },
      "risk": {
        "min_rr": 2.0,
        "position_sizing_enabled": false,
        "account_risk_pct": 0.005
      }
    },
    "persistence": {
      "enabled": true,
      "output_dir": "out",
      "stage_history": {
        "enabled": true,
        "format": "csv",
        "append_only": true,
        "file_name": "stage_history.csv"
      },
      "events": {
        "enabled": true,
        "format": "jsonl",
        "append_only": true,
        "file_name": "events.jsonl"
      },
      "telemetry": {
        "enabled": false,
        "file_name": "telemetry.jsonl"
      }
    },
    "alerts": {
      "enabled": true,
      "console": {
        "enabled": true,
        "include_evidence": true
      },
      "rate_limit": {
        "enabled": true,
        "min_minutes_between_same_event": 60
      },
      "event_types": {
        "stage_change": true,
        "tentative_breakout": true,
        "breakout_confirmed": true,
        "pattern_failed": true
      },
      "min_confidence": {
        "stage_change": 0.40,
        "tentative_breakout": 0.55,
        "breakout_confirmed": 0.70
      }
    }
  },
  "validation": {
